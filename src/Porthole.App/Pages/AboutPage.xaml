<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="Porthole_App.Pages.AboutPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:Porthole_App.Pages"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Padding="24,16,24,16" RowSpacing="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <TextBlock Style="{StaticResource TitleTextBlockStyle}" Text="About" />
        <StackPanel Grid.Row="1" Spacing="12">
            <TextBlock TextWrapping="WrapWholeWords" Opacity="0.8" Text="Porthole is a native Windows dashboard for WSL Containers. It combines a WinUI desktop app with a tray-side backend to manage images, containers, and runtime telemetry." />
            <TextBlock TextWrapping="WrapWholeWords" Opacity="0.8" Text="Use the Images and Containers pages to operate local workloads while keeping session health visible from the dashboard." />
        </StackPanel>
    </Grid>
</Page>
