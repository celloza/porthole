<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="Porthole_App.Pages.SessionsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:models="using:Porthole.Core.Models"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Padding="24,16,24,24" RowSpacing="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!--  Action Bar  -->
        <Border
            Padding="14,10"
            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
            BorderThickness="1"
            CornerRadius="8">
            <Grid ColumnSpacing="8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBox
                    Grid.Column="0"
                    PlaceholderText="New session name"
                    Text="{x:Bind ViewModel.NewSessionName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                <Button
                    Grid.Column="1"
                    MinWidth="120"
                    Command="{x:Bind ViewModel.CreateSessionCommand}"
                    Style="{StaticResource AccentButtonStyle}">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <FontIcon FontSize="12" Glyph="&#xE710;" />
                        <TextBlock Text="New Session" />
                    </StackPanel>
                </Button>
                <Button Grid.Column="2" Command="{x:Bind ViewModel.LoadSessionsCommand}">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <FontIcon FontSize="13" Glyph="&#xE72C;" />
                        <TextBlock Text="Refresh" />
                    </StackPanel>
                </Button>
            </Grid>
        </Border>

        <!--  Content  -->
        <Grid Grid.Row="1" RowSpacing="12">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!--  Status bar  -->
            <Border
                Padding="12,8"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="8">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <ProgressRing
                        Width="16"
                        Height="16"
                        IsActive="{x:Bind ViewModel.IsLoading, Mode=OneWay}" />
                    <TextBlock
                        VerticalAlignment="Center"
                        FontSize="12"
                        Opacity="0.8"
                        Text="{x:Bind ViewModel.StatusMessage, Mode=OneWay}" />
                </StackPanel>
            </Border>

            <!--  Session list  -->
            <ListView
                Grid.Row="1"
                ItemsSource="{x:Bind ViewModel.Sessions}"
                SelectionMode="None">
                <ListView.ItemTemplate>
                    <DataTemplate x:DataType="models:SessionSummary">
                        <Border
                            Margin="0,4"
                            Padding="16,12"
                            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                            BorderThickness="1"
                            CornerRadius="8">
                            <Grid ColumnSpacing="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <!--  Active indicator  -->
                                <FontIcon
                                    Grid.Column="0"
                                    FontSize="16"
                                    Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"
                                    Glyph="&#xE73E;"
                                    Visibility="{x:Bind IsActive}" />

                                <!--  Session info  -->
                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock
                                        FontSize="14"
                                        FontWeight="SemiBold"
                                        Text="{x:Bind Name}" />
                                    <TextBlock
                                        FontSize="11"
                                        Opacity="0.6"
                                        Text="{x:Bind StoragePath}"
                                        TextTrimming="CharacterEllipsis" />
                                </StackPanel>

                                <!--  Switch button  -->
                                <Button
                                    Grid.Column="2"
                                    x:Name="SwitchButton"
                                    MinWidth="80"
                                    Click="SwitchButton_Click"
                                    Tag="{x:Bind}"
                                    IsEnabled="{x:Bind IsNotActive}"
                                    Style="{StaticResource AccentButtonStyle}">
                                    <TextBlock Text="Switch" />
                                </Button>

                                <!--  Delete button  -->
                                <Button
                                    Grid.Column="3"
                                    x:Name="DeleteButton"
                                    Click="DeleteButton_Click"
                                    Tag="{x:Bind}"
                                    IsEnabled="{x:Bind IsNotActive}">
                                    <FontIcon FontSize="12" Glyph="&#xE74D;" />
                                </Button>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
        </Grid>
    </Grid>
</Page>
