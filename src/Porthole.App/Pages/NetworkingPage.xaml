<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="Porthole_App.Pages.NetworkingPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:models="using:Porthole.Core.Models"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <ScrollViewer Padding="24,16,24,24">
        <StackPanel Spacing="16">

            <!--  Toolbar  -->
            <Border
                Padding="14,10"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="8">
                <Grid ColumnSpacing="12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <!--  Status  -->
                    <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                        <ProgressRing
                            Width="16"
                            Height="16"
                            IsActive="{x:Bind ViewModel.IsLoading, Mode=OneWay}" />
                        <TextBlock
                            VerticalAlignment="Center"
                            FontSize="12"
                            Opacity="0.8"
                            Text="{x:Bind ViewModel.StatusMessage, Mode=OneWay}" />
                    </StackPanel>

                    <Button Grid.Column="1" Command="{x:Bind ViewModel.RefreshCommand}">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <FontIcon FontSize="13" Glyph="&#xE72C;" />
                            <TextBlock Text="Refresh" />
                        </StackPanel>
                    </Button>
                </Grid>
            </Border>

            <!--  Network Mode Card  -->
            <Border
                Padding="20,16"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="8">
                <StackPanel Spacing="12">
                    <TextBlock
                        FontSize="16"
                        FontWeight="SemiBold"
                        Text="Network Mode" />

                    <ToggleSwitch
                        x:Name="ConsommeToggle"
                        Header="consomme (relay through Windows)"
                        IsOn="{x:Bind ViewModel.IsConsommeEnabled, Mode=TwoWay}"
                        IsEnabled="{x:Bind ViewModel.IsNotLoading, Mode=OneWay}" />

                    <Border
                        Padding="12,10"
                        Background="{ThemeResource SubtleFillColorSecondaryBrush}"
                        CornerRadius="6">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon
                                FontSize="14"
                                Glyph="&#xE946;"
                                VerticalAlignment="Top"
                                Margin="0,2,0,0" />
                            <TextBlock
                                FontSize="12"
                                Opacity="0.85"
                                Text="{x:Bind ViewModel.ActiveModeDescription, Mode=OneWay}"
                                TextWrapping="WrapWholeWords" />
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>

            <!--  Port Bindings Card  -->
            <Border
                Padding="20,16"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="8">
                <StackPanel Spacing="12">
                    <TextBlock
                        FontSize="16"
                        FontWeight="SemiBold"
                        Text="Active Port Bindings" />

                    <!--  Column headers  -->
                    <Grid ColumnSpacing="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="80" />
                            <ColumnDefinition Width="80" />
                            <ColumnDefinition Width="60" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" FontSize="11" FontWeight="SemiBold" Opacity="0.6" Text="CONTAINER" />
                        <TextBlock Grid.Column="1" FontSize="11" FontWeight="SemiBold" Opacity="0.6" Text="HOST PORT" />
                        <TextBlock Grid.Column="2" FontSize="11" FontWeight="SemiBold" Opacity="0.6" Text="CONT PORT" />
                        <TextBlock Grid.Column="3" FontSize="11" FontWeight="SemiBold" Opacity="0.6" Text="PROTO" />
                    </Grid>
                    <Rectangle Height="1" Fill="{ThemeResource DividerStrokeColorDefaultBrush}" />

                    <ItemsControl ItemsSource="{x:Bind ViewModel.PortBindings, Mode=OneWay}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="models:PortBinding">
                                <Grid
                                    Padding="0,5"
                                    ColumnSpacing="8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="80" />
                                        <ColumnDefinition Width="80" />
                                        <ColumnDefinition Width="60" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock
                                        Grid.Column="0"
                                        FontFamily="Cascadia Mono, Consolas, monospace"
                                        FontSize="12"
                                        Text="{x:Bind ContainerName}"
                                        TextTrimming="CharacterEllipsis" />
                                    <TextBlock
                                        Grid.Column="1"
                                        FontFamily="Cascadia Mono, Consolas, monospace"
                                        FontSize="12"
                                        Text="{x:Bind HostPort}" />
                                    <TextBlock
                                        Grid.Column="2"
                                        FontFamily="Cascadia Mono, Consolas, monospace"
                                        FontSize="12"
                                        Text="{x:Bind ContainerPort}" />
                                    <TextBlock
                                        Grid.Column="3"
                                        FontFamily="Cascadia Mono, Consolas, monospace"
                                        FontSize="12"
                                        Text="{x:Bind Protocol}" />
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <TextBlock
                        FontSize="12"
                        Opacity="0.55"
                        Text="{x:Bind ViewModel.PortBindingsEmptyLabel, Mode=OneWay}" />
                </StackPanel>
            </Border>

            <!--  Proxy Configuration Card  -->
            <Border
                Padding="20,16"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="8">
                <StackPanel Spacing="12">
                    <TextBlock
                        FontSize="16"
                        FontWeight="SemiBold"
                        Text="Host Proxy Configuration" />

                    <TextBlock
                        FontSize="12"
                        Opacity="0.65"
                        Text="When consomme mode is active, Linux containers inherit these host proxy settings automatically."
                        TextWrapping="WrapWholeWords" />

                    <Grid ColumnSpacing="16" RowSpacing="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition />
                            <RowDefinition />
                            <RowDefinition />
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center" Text="HTTP_PROXY" />
                        <TextBlock
                            Grid.Row="0"
                            Grid.Column="1"
                            FontFamily="Cascadia Mono, Consolas, monospace"
                            FontSize="12"
                            Text="{x:Bind ViewModel.HttpProxyDisplay, Mode=OneWay}"
                            TextTrimming="CharacterEllipsis" />

                        <TextBlock Grid.Row="1" Grid.Column="0" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center" Text="HTTPS_PROXY" />
                        <TextBlock
                            Grid.Row="1"
                            Grid.Column="1"
                            FontFamily="Cascadia Mono, Consolas, monospace"
                            FontSize="12"
                            Text="{x:Bind ViewModel.HttpsProxyDisplay, Mode=OneWay}"
                            TextTrimming="CharacterEllipsis" />

                        <TextBlock Grid.Row="2" Grid.Column="0" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center" Text="NO_PROXY" />
                        <TextBlock
                            Grid.Row="2"
                            Grid.Column="1"
                            FontFamily="Cascadia Mono, Consolas, monospace"
                            FontSize="12"
                            Text="{x:Bind ViewModel.NoProxyDisplay, Mode=OneWay}"
                            TextTrimming="CharacterEllipsis" />
                    </Grid>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>
