<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="Porthole_App.Pages.ContainersPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:models="using:Porthole.Core.Models"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Padding="24,20,24,32" ColumnSpacing="20" RowSpacing="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2*" />
            <ColumnDefinition Width="320" />
        </Grid.ColumnDefinitions>

        <Border Grid.Row="0" Grid.ColumnSpan="2" Padding="18" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="16">
            <Grid ColumnSpacing="12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Spacing="4">
                    <TextBlock FontSize="16" FontWeight="SemiBold" Text="Container inventory" />
                    <TextBlock Opacity="0.72" Text="Live container records from the tray host via named pipe." />
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon Glyph="&#xE7BA;" />
                        <TextBlock Opacity="0.82" Text="{x:Bind ViewModel.ElevationWarningText, Mode=OneWay}" TextWrapping="WrapWholeWords" />
                    </StackPanel>
                    <TextBlock Opacity="0.72" Text="{x:Bind ViewModel.ActionStatus, Mode=OneWay}" TextWrapping="WrapWholeWords" />
                </StackPanel>
                <StackPanel Grid.Column="1" Spacing="8" HorizontalAlignment="Right">
                    <TextBlock HorizontalAlignment="Right" Opacity="0.72" Text="{x:Bind ViewModel.ContainerCountLabel, Mode=OneWay}" />
                    <TextBlock HorizontalAlignment="Right" Opacity="0.72" Text="{x:Bind ViewModel.RunningCountLabel, Mode=OneWay}" />
                    <Button MinWidth="120" Command="{x:Bind ViewModel.RefreshCommand}" Content="Refresh" />
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="1" Grid.Column="0" Padding="0" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="16">
            <ListView ItemsSource="{x:Bind ViewModel.Containers, Mode=OneWay}" SelectedItem="{x:Bind ViewModel.SelectedContainer, Mode=TwoWay}">
                <ListView.ItemTemplate>
                    <DataTemplate x:DataType="models:ContainerSummary">
                        <Grid Padding="18,14" ColumnSpacing="16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Spacing="4">
                                <TextBlock FontWeight="SemiBold" Text="{x:Bind DisplayName}" />
                                <TextBlock Opacity="0.72" Text="{x:Bind ShortId}" />
                                <TextBlock Opacity="0.72" Text="{x:Bind Image}" TextTrimming="CharacterEllipsis" />
                            </StackPanel>
                            <TextBlock Grid.Column="1" VerticalAlignment="Center" Opacity="0.72" Text="{x:Bind StateText}" />
                        </Grid>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
        </Border>

        <Border Grid.Row="1" Grid.Column="1" Padding="18" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="16">
            <StackPanel Spacing="12">
                <TextBlock FontSize="16" FontWeight="SemiBold" Text="Selection" />
                <TextBlock FontWeight="SemiBold" Text="{x:Bind ViewModel.SelectedContainerTitle, Mode=OneWay}" TextWrapping="WrapWholeWords" />
                <TextBlock Opacity="0.72" Text="{x:Bind ViewModel.SelectedContainerSubtitle, Mode=OneWay}" TextWrapping="WrapWholeWords" />
                <Button Command="{x:Bind ViewModel.StartContainerCommand}" Content="Start container" />
                <Button Command="{x:Bind ViewModel.StopContainerCommand}" Content="Stop container" />
                <Button Command="{x:Bind ViewModel.RemoveContainerCommand}" Content="Remove container" />
                <TextBlock Margin="0,8,0,0" FontSize="16" FontWeight="SemiBold" Text="Pods tree" />
                <TextBlock Opacity="0.72" Text="{x:Bind ViewModel.PodsStatus, Mode=OneWay}" TextWrapping="WrapWholeWords" />
                <ScrollViewer Height="240" VerticalScrollBarVisibility="Auto">
                    <TextBlock FontFamily="Cascadia Mono" Text="{x:Bind ViewModel.PodTreeText, Mode=OneWay}" TextWrapping="NoWrap" />
                </ScrollViewer>
            </StackPanel>
        </Border>
    </Grid>
</Page>