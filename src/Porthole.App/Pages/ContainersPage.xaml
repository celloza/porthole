<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="Porthole_App.Pages.ContainersPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:models="using:Porthole.Core.Models"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Padding="24,16,24,24" RowSpacing="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!--  Action Bar  -->
        <Border
            Padding="14,10"
            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
            BorderThickness="1"
            CornerRadius="8">
            <Grid ColumnSpacing="16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <!--  Elevation notice  -->
                <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                    <FontIcon
                        FontSize="14"
                        Glyph="&#xE7BA;"
                        Opacity="0.7"
                        VerticalAlignment="Center" />
                    <TextBlock
                        FontSize="12"
                        Opacity="0.65"
                        Text="{x:Bind ViewModel.ElevationWarningText, Mode=OneWay}"
                        TextTrimming="CharacterEllipsis"
                        VerticalAlignment="Center" />
                </StackPanel>

                <!--  Stats and refresh  -->
                <StackPanel
                    Grid.Column="1"
                    Orientation="Horizontal"
                    Spacing="16"
                    VerticalAlignment="Center">
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock
                            FontSize="12"
                            FontWeight="SemiBold"
                            HorizontalAlignment="Right"
                            Text="{x:Bind ViewModel.ContainerCountLabel, Mode=OneWay}" />
                        <TextBlock
                            FontSize="11"
                            HorizontalAlignment="Right"
                            Opacity="0.6"
                            Text="{x:Bind ViewModel.RunningCountLabel, Mode=OneWay}" />
                    </StackPanel>
                    <Button Command="{x:Bind ViewModel.RefreshCommand}">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <FontIcon FontSize="13" Glyph="&#xE72C;" />
                            <TextBlock Text="Refresh Inventory" />
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!--  Master-Detail  -->
        <Grid Grid.Row="1" ColumnSpacing="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="360" />
            </Grid.ColumnDefinitions>

            <!--  Master: container list  -->
            <Border
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="12">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <!--  List header  -->
                    <Grid Padding="16,12,16,10" ColumnSpacing="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock
                            FontSize="13"
                            FontWeight="SemiBold"
                            Text="Container Inventory"
                            VerticalAlignment="Center" />
                        <TextBlock
                            Grid.Column="1"
                            FontSize="11"
                            Opacity="0.65"
                            Text="{x:Bind ViewModel.ActionStatus, Mode=OneWay}"
                            TextTrimming="CharacterEllipsis"
                            VerticalAlignment="Center" />
                    </Grid>

                    <!--  Container ListView  -->
                    <ListView
                        Grid.Row="1"
                        ItemsSource="{x:Bind ViewModel.Containers, Mode=OneWay}"
                        SelectedItem="{x:Bind ViewModel.SelectedContainer, Mode=TwoWay}">
                        <ListView.ItemContainerStyle>
                            <Style TargetType="ListViewItem">
                                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                <Setter Property="Padding" Value="12,0" />
                            </Style>
                        </ListView.ItemContainerStyle>
                        <ListView.ItemTemplate>
                            <DataTemplate x:DataType="models:ContainerSummary">
                                <Grid Padding="0,10" ColumnSpacing="12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <!--  Placeholder icon  -->
                                    <FontIcon
                                        Grid.Column="0"
                                        FontSize="20"
                                        Glyph="&#xE8C9;"
                                        Opacity="0.55"
                                        VerticalAlignment="Center" />

                                    <!--  Name and ID  -->
                                    <StackPanel Grid.Column="1" Spacing="3" VerticalAlignment="Center">
                                        <TextBlock FontSize="13" FontWeight="SemiBold" Text="{x:Bind DisplayName}" />
                                        <Grid ColumnSpacing="4">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock
                                                Grid.Column="0"
                                                FontFamily="Consolas"
                                                FontSize="11"
                                                Opacity="0.5"
                                                Text="{x:Bind ShortId}"
                                                VerticalAlignment="Center" />
                                            <Button
                                                Grid.Column="1"
                                                Width="22"
                                                Height="22"
                                                MinWidth="0"
                                                Padding="0"
                                                Background="Transparent"
                                                BorderThickness="0"
                                                Click="ItemCopyIdButton_Click"
                                                Tag="{x:Bind Id}"
                                                ToolTipService.ToolTip="Copy container ID"
                                                VerticalAlignment="Center">
                                                <FontIcon FontSize="11" Glyph="&#xE8C8;" />
                                            </Button>
                                        </Grid>
                                        <TextBlock
                                            FontSize="11"
                                            Opacity="0.5"
                                            Text="{x:Bind Image}"
                                            TextTrimming="CharacterEllipsis" />
                                    </StackPanel>

                                    <!--  State  -->
                                    <StackPanel
                                        Grid.Column="2"
                                        HorizontalAlignment="Right"
                                        Orientation="Horizontal"
                                        Spacing="5"
                                        VerticalAlignment="Center">
                                        <FontIcon
                                            FontSize="11"
                                            Glyph="{x:Bind StateGlyph}"
                                            Opacity="0.65"
                                            VerticalAlignment="Center" />
                                        <TextBlock FontSize="12" Opacity="0.72" Text="{x:Bind StateText}" />
                                    </StackPanel>
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </Grid>
            </Border>

            <!--  Detail column  -->
            <Grid Grid.Column="1">

                <!--  Empty state  -->
                <Border
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="12"
                    Visibility="{x:Bind GetEmptyStateVisibility(ViewModel.SelectedContainer), Mode=OneWay}">
                    <StackPanel
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Spacing="10">
                        <FontIcon FontSize="36" Glyph="&#xE8EF;" HorizontalAlignment="Center" Opacity="0.25" />
                        <TextBlock
                            FontSize="13"
                            HorizontalAlignment="Center"
                            Opacity="0.45"
                            Text="Select a container to view details" />
                    </StackPanel>
                </Border>

                <!--  Container detail card  -->
                <Border
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="12"
                    Visibility="{x:Bind GetDetailVisibility(ViewModel.SelectedContainer), Mode=OneWay}">
                    <ScrollViewer>
                        <StackPanel Margin="16" Spacing="20">

                            <!--  Container title  -->
                            <StackPanel Spacing="2">
                                <TextBlock
                                    FontSize="15"
                                    FontWeight="SemiBold"
                                    Text="{x:Bind ViewModel.SelectedContainer.DisplayName, Mode=OneWay}"
                                    TextWrapping="WrapWholeWords" />
                                <TextBlock
                                    FontSize="11"
                                    Opacity="0.6"
                                    Text="{x:Bind ViewModel.SelectedContainer.MetadataLine, Mode=OneWay}"
                                    TextWrapping="WrapWholeWords" />
                            </StackPanel>

                            <!--  Details section  -->
                            <StackPanel Spacing="10">
                                <TextBlock
                                    FontSize="10"
                                    FontWeight="SemiBold"
                                    Opacity="0.5"
                                    Text="DETAILS" />

                                <!--  Full ID with copy  -->
                                <Grid ColumnSpacing="8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock
                                        Grid.Column="0"
                                        FontFamily="Consolas"
                                        FontSize="11"
                                        Opacity="0.7"
                                        Text="{x:Bind ViewModel.SelectedContainer.Id, Mode=OneWay}"
                                        TextWrapping="Wrap"
                                        VerticalAlignment="Top" />
                                    <Button
                                        Grid.Column="1"
                                        Width="28"
                                        Height="28"
                                        MinWidth="0"
                                        Padding="0"
                                        Command="{x:Bind ViewModel.CopyIdCommand}"
                                        ToolTipService.ToolTip="Copy container ID"
                                        VerticalAlignment="Top">
                                        <FontIcon FontSize="12" Glyph="&#xE8C8;" />
                                    </Button>
                                </Grid>

                                <!--  Image  -->
                                <StackPanel Orientation="Horizontal" Spacing="5">
                                    <FontIcon FontSize="11" Glyph="&#xE7B8;" Opacity="0.55" VerticalAlignment="Center" />
                                    <TextBlock
                                        FontSize="12"
                                        Opacity="0.75"
                                        Text="{x:Bind ViewModel.SelectedContainer.Image, Mode=OneWay}"
                                        TextWrapping="WrapWholeWords" />
                                </StackPanel>

                                <!--  State  -->
                                <StackPanel Orientation="Horizontal" Spacing="5">
                                    <FontIcon
                                        FontSize="11"
                                        Glyph="{x:Bind ViewModel.SelectedContainer.StateGlyph, Mode=OneWay}"
                                        Opacity="0.65"
                                        VerticalAlignment="Center" />
                                    <TextBlock FontSize="12" Opacity="0.75" Text="{x:Bind ViewModel.SelectedContainer.StateText, Mode=OneWay}" />
                                </StackPanel>
                            </StackPanel>

                            <!--  Lifecycle actions  -->
                            <StackPanel Spacing="8">
                                <TextBlock
                                    FontSize="10"
                                    FontWeight="SemiBold"
                                    Opacity="0.5"
                                    Text="LIFECYCLE" />
                                <Button Command="{x:Bind ViewModel.StartContainerCommand}">
                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                        <FontIcon FontSize="12" Glyph="&#xE768;" />
                                        <TextBlock Text="Start Container" />
                                    </StackPanel>
                                </Button>
                                <Button Command="{x:Bind ViewModel.StopContainerCommand}">
                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                        <FontIcon FontSize="12" Glyph="&#xE71A;" />
                                        <TextBlock Text="Stop Container" />
                                    </StackPanel>
                                </Button>
                            </StackPanel>

                            <!--  Remove action  -->
                            <StackPanel Spacing="8">
                                <TextBlock
                                    FontSize="10"
                                    FontWeight="SemiBold"
                                    Opacity="0.5"
                                    Text="DANGER ZONE" />
                                <Button
                                    Command="{x:Bind ViewModel.RemoveContainerCommand}"
                                    Foreground="{ThemeResource SystemFillColorCriticalBrush}">
                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                        <FontIcon FontSize="12" Glyph="&#xE74D;" />
                                        <TextBlock Text="Remove Container" />
                                    </StackPanel>
                                </Button>
                            </StackPanel>

                            <!--  Pods tree  -->
                            <StackPanel Spacing="8">
                                <TextBlock
                                    FontSize="10"
                                    FontWeight="SemiBold"
                                    Opacity="0.5"
                                    Text="PODS" />
                                <TextBlock
                                    FontSize="11"
                                    Opacity="0.6"
                                    Text="{x:Bind ViewModel.PodsStatus, Mode=OneWay}"
                                    TextWrapping="WrapWholeWords" />
                                <ScrollViewer
                                    Height="180"
                                    HorizontalScrollBarVisibility="Auto"
                                    HorizontalScrollMode="Enabled"
                                    VerticalScrollBarVisibility="Auto">
                                    <TextBlock
                                        FontFamily="Cascadia Mono"
                                        FontSize="11"
                                        Text="{x:Bind ViewModel.PodTreeText, Mode=OneWay}"
                                        TextWrapping="NoWrap" />
                                </ScrollViewer>
                            </StackPanel>

                            <!--  Status feedback  -->
                            <TextBlock
                                FontSize="11"
                                Opacity="0.6"
                                Text="{x:Bind ViewModel.ActionStatus, Mode=OneWay}"
                                TextWrapping="WrapWholeWords" />

                        </StackPanel>
                    </ScrollViewer>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</Page>