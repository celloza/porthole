<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="Porthole_App.Pages.VolumesPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:models="using:Porthole.Core.Models"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Padding="24,16,24,24" RowSpacing="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!--  Action Bar  -->
        <Border
            Padding="14,10"
            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
            BorderThickness="1"
            CornerRadius="8">
            <Grid ColumnSpacing="8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBox
                    Grid.Column="0"
                    PlaceholderText="New volume name"
                    IsEnabled="{x:Bind ViewModel.IsNotLoading, Mode=OneWay}"
                    Text="{x:Bind ViewModel.NewVolumeName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                <Button
                    Grid.Column="1"
                    MinWidth="130"
                    Command="{x:Bind ViewModel.CreateVolumeCommand}"
                    IsEnabled="{x:Bind ViewModel.IsNotLoading, Mode=OneWay}"
                    Style="{StaticResource AccentButtonStyle}">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <FontIcon FontSize="12" Glyph="&#xE710;" />
                        <TextBlock Text="New Volume" />
                    </StackPanel>
                </Button>
                <Button
                    Grid.Column="2"
                    MinWidth="80"
                    Command="{x:Bind ViewModel.PruneVolumesCommand}"
                    IsEnabled="{x:Bind ViewModel.IsNotLoading, Mode=OneWay}">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <FontIcon FontSize="12" Glyph="&#xE74D;" />
                        <TextBlock Text="Prune" />
                    </StackPanel>
                </Button>
                <Button
                    Grid.Column="3"
                    Command="{x:Bind ViewModel.RefreshCommand}"
                    IsEnabled="{x:Bind ViewModel.IsNotLoading, Mode=OneWay}">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <FontIcon FontSize="13" Glyph="&#xE72C;" />
                        <TextBlock Text="Refresh" />
                    </StackPanel>
                </Button>
            </Grid>
        </Border>

        <!--  Content  -->
        <Grid Grid.Row="1" RowSpacing="12">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!--  Status bar  -->
            <Border
                Padding="12,8"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="8">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <ProgressRing
                        Width="16"
                        Height="16"
                        Margin="0,0,8,0"
                        IsActive="{x:Bind ViewModel.IsLoading, Mode=OneWay}"
                        VerticalAlignment="Center" />
                    <TextBlock
                        Grid.Column="1"
                        VerticalAlignment="Center"
                        FontSize="12"
                        Opacity="0.8"
                        Text="{x:Bind ViewModel.StatusMessage, Mode=OneWay}" />
                    <TextBlock
                        Grid.Column="2"
                        VerticalAlignment="Center"
                        FontSize="12"
                        FontWeight="SemiBold"
                        Opacity="0.65"
                        Text="{x:Bind ViewModel.VolumeCountLabel, Mode=OneWay}" />
                </Grid>
            </Border>

            <!--  Volume list  -->
            <Border
                Grid.Row="1"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="12">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <!--  Column headers  -->
                    <Grid
                        Padding="16,10,16,8"
                        ColumnSpacing="8"
                        BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                        BorderThickness="0,0,0,1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="96" />
                            <ColumnDefinition Width="84" />
                            <ColumnDefinition Width="110" />
                            <ColumnDefinition Width="44" />
                            <ColumnDefinition Width="44" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" FontSize="11" FontWeight="SemiBold" Opacity="0.6" Text="SOURCE / TARGET" />
                        <TextBlock Grid.Column="1" FontSize="11" FontWeight="SemiBold" Opacity="0.6" Text="DRIVER" />
                        <TextBlock Grid.Column="2" FontSize="11" FontWeight="SemiBold" Opacity="0.6" Text="SIZE" />
                        <TextBlock Grid.Column="3" FontSize="11" FontWeight="SemiBold" Opacity="0.6" Text="TELEMETRY" />
                    </Grid>

                    <ScrollViewer Grid.Row="1">
                        <ItemsControl ItemsSource="{x:Bind ViewModel.Volumes, Mode=OneWay}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="models:VolumeSummary">
                                    <Grid
                                        Padding="16,8"
                                        ColumnSpacing="8"
                                        BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                                        BorderThickness="0,0,0,1">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="96" />
                                            <ColumnDefinition Width="84" />
                                            <ColumnDefinition Width="110" />
                                            <ColumnDefinition Width="44" />
                                            <ColumnDefinition Width="44" />
                                        </Grid.ColumnDefinitions>

                                        <!--  Source / target  -->
                                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                            <TextBlock
                                                FontFamily="Cascadia Mono, Consolas, monospace"
                                                FontSize="13"
                                                FontWeight="SemiBold"
                                                Text="{x:Bind DisplayName}"
                                                TextTrimming="CharacterEllipsis" />
                                            <TextBlock
                                                FontSize="11"
                                                Opacity="0.55"
                                                Text="{x:Bind PathSummary}"
                                                TextTrimming="CharacterEllipsis" />
                                        </StackPanel>

                                        <!--  Driver  -->
                                        <TextBlock
                                            Grid.Column="1"
                                            VerticalAlignment="Center"
                                            FontFamily="Cascadia Mono, Consolas, monospace"
                                            FontSize="12"
                                            Text="{x:Bind DriverDisplay}" />

                                        <!--  Size  -->
                                        <TextBlock
                                            Grid.Column="2"
                                            VerticalAlignment="Center"
                                            FontFamily="Cascadia Mono, Consolas, monospace"
                                            FontSize="12"
                                            Text="{x:Bind SizeLabel}" />

                                        <!--  Telemetry -->
                                        <StackPanel
                                            Grid.Column="3"
                                            Orientation="Vertical"
                                            Spacing="4"
                                            VerticalAlignment="Center">
                                            <TextBlock
                                                FontSize="11"
                                                FontWeight="SemiBold"
                                                Text="{x:Bind TypeLabel}" />
                                            <TextBlock
                                                FontSize="11"
                                                Opacity="0.7"
                                                Text="{x:Bind AccessModeLabel}" />
                                            <TextBlock
                                                FontSize="11"
                                                Opacity="0.7"
                                                Text="{x:Bind ThroughputClassDisplay}" />
                                            <StackPanel Orientation="Horizontal" Spacing="4">
                                                <FontIcon
                                                    FontSize="11"
                                                    Glyph="{x:Bind InUseGlyph}" />
                                                <TextBlock
                                                    FontSize="12"
                                                    Text="{x:Bind InUseLabel}" />
                                            </StackPanel>
                                        </StackPanel>

                                        <!--  Copy mount string button  -->
                                        <Button
                                            Grid.Column="4"
                                            x:Name="CopyMountStringButton"
                                            Click="CopyMountStringButton_Click"
                                            Tag="{x:Bind}"
                                            VerticalAlignment="Center"
                                            ToolTipService.ToolTip="Copy mount string">
                                            <FontIcon FontSize="12" Glyph="&#xE8C8;" />
                                        </Button>

                                        <!--  Delete button  -->
                                        <Button
                                            Grid.Column="5"
                                            x:Name="DeleteVolumeButton"
                                            Click="DeleteVolumeButton_Click"
                                            IsEnabled="{x:Bind CanDelete}"
                                            Tag="{x:Bind}"
                                            VerticalAlignment="Center"
                                            ToolTipService.ToolTip="{x:Bind DeleteToolTip}">
                                            <FontIcon FontSize="12" Glyph="&#xE74D;" />
                                        </Button>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Page>
