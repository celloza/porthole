<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="Porthole_App.Pages.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:Porthole_App.Pages"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <StackPanel Padding="24,20,24,32" Spacing="16">
        <TextBlock Opacity="0.72" Text="Settings for startup behavior, tray integration, and default runtime preferences will appear here." TextWrapping="WrapWholeWords" />
        <TextBlock Opacity="0.72" Text="Current changes apply immediately through the main dashboard pages and the tray host." TextWrapping="WrapWholeWords" />
    </StackPanel>
</Page>
