<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="Porthole_App.Pages.ImagesPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:models="using:Porthole.Core.Models"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Padding="24,16,24,24" RowSpacing="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!--  Action Bar  -->
        <Border
            Padding="14,10"
            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
            BorderThickness="1"
            CornerRadius="8">
            <StackPanel Spacing="6">

                <!--  All four controls in one row  -->
                <Grid ColumnSpacing="8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBox
                        Grid.Column="0"
                        PlaceholderText="Pull image reference"
                        Text="{x:Bind ViewModel.ImageReference, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                    <Button
                        Grid.Column="1"
                        MinWidth="80"
                        Command="{x:Bind ViewModel.PullImageCommand}"
                        Style="{StaticResource AccentButtonStyle}">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <FontIcon FontSize="12" Glyph="&#xE896;" />
                            <TextBlock Text="Pull" />
                        </StackPanel>
                    </Button>
                    <Button Grid.Column="2" Command="{x:Bind ViewModel.RefreshCommand}">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <FontIcon FontSize="13" Glyph="&#xE72C;" />
                            <TextBlock Text="Refresh Inventory" />
                        </StackPanel>
                    </Button>
                    <Button Grid.Column="3" Click="PruneImagesButton_Click">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <FontIcon FontSize="13" Glyph="&#xE74D;" />
                            <TextBlock Text="Prune Unused" />
                        </StackPanel>
                    </Button>
                </Grid>

                <!--  Pull progress and status (full width, below all buttons)  -->
                <ProgressBar
                    Height="3"
                    Maximum="100"
                    Minimum="0"
                    Opacity="{x:Bind ViewModel.PullProgressOpacity, Mode=OneWay}"
                    ShowError="False"
                    ShowPaused="False"
                    Value="{x:Bind ViewModel.PullProgressPercent, Mode=OneWay}" />
                <TextBlock
                    FontSize="11"
                    Opacity="0.65"
                    Text="{x:Bind ViewModel.PullStatus, Mode=OneWay}"
                    TextTrimming="CharacterEllipsis" />

            </StackPanel>
        </Border>

        <!--  Master-Detail  -->
        <Grid Grid.Row="1" ColumnSpacing="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="360" />
            </Grid.ColumnDefinitions>

            <!--  Master: image cache list  -->
            <Border
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="12">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <!--  List header  -->
                    <Grid Padding="16,12,16,10" ColumnSpacing="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock
                            FontSize="13"
                            FontWeight="SemiBold"
                            Text="Image Cache"
                            VerticalAlignment="Center" />
                        <StackPanel
                            Grid.Column="1"
                            Orientation="Horizontal"
                            Spacing="6"
                            VerticalAlignment="Center">
                            <ProgressRing
                                Width="14"
                                Height="14"
                                IsActive="{x:Bind ViewModel.IsInitialLoadInProgress, Mode=OneWay}"
                                Opacity="{x:Bind ViewModel.InitialLoadIndicatorOpacity, Mode=OneWay}" />
                            <TextBlock
                                FontSize="11"
                                Opacity="0.65"
                                Text="{x:Bind ViewModel.ImageCountLabel, Mode=OneWay}"
                                VerticalAlignment="Center" />
                        </StackPanel>
                    </Grid>

                    <!--  Image ListView  -->
                    <ListView
                        Grid.Row="1"
                        ItemsSource="{x:Bind ViewModel.Images, Mode=OneWay}"
                        SelectedItem="{x:Bind ViewModel.SelectedImage, Mode=TwoWay}">
                        <ListView.ItemContainerStyle>
                            <Style TargetType="ListViewItem">
                                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                <Setter Property="Padding" Value="12,0" />
                            </Style>
                        </ListView.ItemContainerStyle>
                        <ListView.ItemTemplate>
                            <DataTemplate x:DataType="models:ImageSummary">
                                <Grid Padding="0,10" ColumnSpacing="12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <!--  Placeholder icon  -->
                                    <FontIcon
                                        Grid.Column="0"
                                        FontSize="20"
                                        Glyph="&#xE7B8;"
                                        Opacity="0.55"
                                        VerticalAlignment="Center" />

                                    <!--  Name and SHA  -->
                                    <StackPanel Grid.Column="1" Spacing="3" VerticalAlignment="Center">
                                        <TextBlock FontSize="13" FontWeight="SemiBold" Text="{x:Bind DisplayName}" />
                                        <Grid ColumnSpacing="4">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock
                                                Grid.Column="0"
                                                FontFamily="Consolas"
                                                FontSize="11"
                                                Opacity="0.5"
                                                Text="{x:Bind Id}"
                                                TextTrimming="CharacterEllipsis"
                                                VerticalAlignment="Center" />
                                            <Button
                                                Grid.Column="1"
                                                Width="22"
                                                Height="22"
                                                MinWidth="0"
                                                Padding="0"
                                                Background="Transparent"
                                                BorderThickness="0"
                                                Click="ItemCopyIdButton_Click"
                                                Tag="{x:Bind Id}"
                                                ToolTipService.ToolTip="Copy SHA"
                                                VerticalAlignment="Center">
                                                <FontIcon FontSize="11" Glyph="&#xE8C8;" />
                                            </Button>
                                        </Grid>
                                    </StackPanel>

                                    <!--  Size and age  -->
                                    <StackPanel
                                        Grid.Column="2"
                                        HorizontalAlignment="Right"
                                        Spacing="3"
                                        VerticalAlignment="Center">
                                        <StackPanel HorizontalAlignment="Right" Orientation="Horizontal" Spacing="4">
                                            <FontIcon
                                                FontSize="10"
                                                Glyph="&#xEDA2;"
                                                Opacity="0.5"
                                                VerticalAlignment="Center" />
                                            <TextBlock FontSize="11" Opacity="0.72" Text="{x:Bind SizeLabel}" />
                                        </StackPanel>
                                        <StackPanel HorizontalAlignment="Right" Orientation="Horizontal" Spacing="4">
                                            <FontIcon
                                                FontSize="10"
                                                Glyph="&#xE787;"
                                                Opacity="0.5"
                                                VerticalAlignment="Center" />
                                            <TextBlock FontSize="11" Opacity="0.55" Text="{x:Bind CreatedRelative}" />
                                        </StackPanel>
                                    </StackPanel>
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </Grid>
            </Border>

            <!--  Detail column  -->
            <Grid Grid.Column="1">

                <!--  Empty state  -->
                <Border
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="12"
                    Visibility="{x:Bind GetEmptyStateVisibility(ViewModel.SelectedImage), Mode=OneWay}">
                    <StackPanel
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Spacing="10">
                        <FontIcon FontSize="36" Glyph="&#xE8EF;" Opacity="0.25" HorizontalAlignment="Center" />
                        <TextBlock
                            FontSize="13"
                            HorizontalAlignment="Center"
                            Opacity="0.45"
                            Text="Select an image to view details" />
                    </StackPanel>
                </Border>

                <!--  Image detail card  -->
                <Border
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="12"
                    Visibility="{x:Bind GetDetailVisibility(ViewModel.SelectedImage), Mode=OneWay}">
                    <ScrollViewer>
                        <StackPanel Margin="16" Spacing="20">

                            <!--  Image title  -->
                            <StackPanel Spacing="2">
                                <TextBlock
                                    FontSize="15"
                                    FontWeight="SemiBold"
                                    Text="{x:Bind ViewModel.SelectedImage.DisplayName, Mode=OneWay}"
                                    TextWrapping="WrapWholeWords" />
                                <TextBlock
                                    FontSize="11"
                                    Opacity="0.6"
                                    Text="{x:Bind ViewModel.SelectedImage.Reference, Mode=OneWay}"
                                    TextWrapping="WrapWholeWords" />
                            </StackPanel>

                            <!--  Details section  -->
                            <StackPanel Spacing="10">
                                <TextBlock
                                    FontSize="10"
                                    FontWeight="SemiBold"
                                    Opacity="0.5"
                                    Text="DETAILS" />

                                <!--  Full SHA with copy  -->
                                <Grid ColumnSpacing="8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock
                                        Grid.Column="0"
                                        FontFamily="Consolas"
                                        FontSize="11"
                                        Opacity="0.7"
                                        Text="{x:Bind ViewModel.SelectedImage.Id, Mode=OneWay}"
                                        TextWrapping="Wrap"
                                        VerticalAlignment="Top" />
                                    <Button
                                        Grid.Column="1"
                                        Width="28"
                                        Height="28"
                                        MinWidth="0"
                                        Padding="0"
                                        Command="{x:Bind ViewModel.CopyShaCommand}"
                                        ToolTipService.ToolTip="Copy full SHA"
                                        VerticalAlignment="Top">
                                        <FontIcon FontSize="12" Glyph="&#xE8C8;" />
                                    </Button>
                                </Grid>

                                <!--  Size and created  -->
                                <StackPanel Orientation="Horizontal" Spacing="16">
                                    <StackPanel Orientation="Horizontal" Spacing="5">
                                        <FontIcon FontSize="11" Glyph="&#xEDA2;" Opacity="0.55" VerticalAlignment="Center" />
                                        <TextBlock FontSize="12" Opacity="0.75" Text="{x:Bind ViewModel.SelectedImage.SizeLabel, Mode=OneWay}" />
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" Spacing="5">
                                        <FontIcon FontSize="11" Glyph="&#xE787;" Opacity="0.55" VerticalAlignment="Center" />
                                        <TextBlock FontSize="12" Opacity="0.75" Text="{x:Bind ViewModel.SelectedImage.CreatedRelative, Mode=OneWay}" />
                                    </StackPanel>
                                </StackPanel>
                            </StackPanel>

                            <!--  Tag action section  -->
                            <StackPanel Spacing="8">
                                <TextBlock
                                    FontSize="10"
                                    FontWeight="SemiBold"
                                    Opacity="0.5"
                                    Text="TAG IMAGE" />
                                <Grid ColumnSpacing="8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBox
                                        Grid.Column="0"
                                        PlaceholderText="local/dev:latest"
                                        Text="{x:Bind ViewModel.NewTag, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                    <Button Grid.Column="1" Command="{x:Bind ViewModel.TagImageCommand}">
                                        <StackPanel Orientation="Horizontal" Spacing="6">
                                            <FontIcon FontSize="12" Glyph="&#xE1CB;" />
                                            <TextBlock Text="Apply Tag" />
                                        </StackPanel>
                                    </Button>
                                </Grid>
                            </StackPanel>

                            <!--  Delete action section  -->
                            <StackPanel Spacing="8">
                                <TextBlock
                                    FontSize="10"
                                    FontWeight="SemiBold"
                                    Opacity="0.5"
                                    Text="DANGER ZONE" />
                                <Button
                                    Command="{x:Bind ViewModel.DeleteImageCommand}"
                                    Style="{StaticResource DangerButtonStyle}"
                                    ToolTipService.ToolTip="Permanently delete this image">
                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                        <FontIcon FontSize="12" Glyph="&#xE74D;" />
                                        <TextBlock Text="Delete Image" />
                                    </StackPanel>
                                </Button>
                            </StackPanel>

                            <!--  Status feedback  -->
                            <TextBlock
                                FontSize="11"
                                Opacity="0.6"
                                Text="{x:Bind ViewModel.ActionStatus, Mode=OneWay}"
                                TextWrapping="WrapWholeWords" />

                        </StackPanel>
                    </ScrollViewer>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</Page>