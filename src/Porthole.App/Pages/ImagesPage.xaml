<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="Porthole_App.Pages.ImagesPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:models="using:Porthole.Core.Models"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <ScrollViewer>
        <Grid Padding="24,20,24,32" ColumnSpacing="20" RowSpacing="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*" />
                <ColumnDefinition Width="320" />
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Row="0" Grid.ColumnSpan="2" Opacity="0.72" Text="Pull, tag, prune, and remove OCI images from your local cache. Progress and inventory updates are streamed from the tray backend." TextWrapping="WrapWholeWords" />

            <Border Grid.Row="1" Grid.Column="0" Padding="18" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="16">
                <StackPanel Spacing="12">
                    <TextBlock FontSize="16" FontWeight="SemiBold" Text="Pull image" />
                    <TextBox Header="Image reference" PlaceholderText="mcr.microsoft.com/oss/nginx/nginx:latest" Text="{x:Bind ViewModel.ImageReference, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                    <Grid ColumnSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <ProgressBar Grid.Column="0" Height="8" Minimum="0" Maximum="100" Value="{x:Bind ViewModel.PullProgressPercent, Mode=OneWay}" ShowError="False" ShowPaused="False" Opacity="{x:Bind ViewModel.PullProgressOpacity, Mode=OneWay}" />
                        <Button Grid.Column="1" MinWidth="120" Command="{x:Bind ViewModel.PullImageCommand}" Content="Pull image" />
                    </Grid>
                    <TextBlock Opacity="0.72" Text="{x:Bind ViewModel.PullStatus, Mode=OneWay}" TextWrapping="WrapWholeWords" />
                </StackPanel>
            </Border>

            <Border Grid.Row="1" Grid.Column="1" Padding="18" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="16">
                <StackPanel Spacing="12">
                    <TextBlock FontSize="16" FontWeight="SemiBold" Text="Actions" />
                    <Button Command="{x:Bind ViewModel.RefreshCommand}" Content="Refresh inventory" />
                    <Button Command="{x:Bind ViewModel.PruneImagesCommand}" Content="Prune unused images" />
                    <TextBlock Opacity="0.72" Text="{x:Bind ViewModel.ActionStatus, Mode=OneWay}" TextWrapping="WrapWholeWords" />
                </StackPanel>
            </Border>

            <Border Grid.Row="2" Grid.Column="0" Padding="0" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="16">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <Grid Padding="18,18,18,12" ColumnSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock FontSize="16" FontWeight="SemiBold" Text="Local image cache" />
                        <TextBlock Grid.Column="1" Opacity="0.72" Text="{x:Bind ViewModel.ImageCountLabel, Mode=OneWay}" VerticalAlignment="Center" />
                    </Grid>
                    <ListView Grid.Row="1" ItemsSource="{x:Bind ViewModel.Images, Mode=OneWay}" SelectedItem="{x:Bind ViewModel.SelectedImage, Mode=TwoWay}">
                        <ListView.ItemTemplate>
                            <DataTemplate x:DataType="models:ImageSummary">
                                <Grid Padding="18,14" ColumnSpacing="16">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Spacing="4">
                                        <TextBlock FontWeight="SemiBold" Text="{x:Bind DisplayName}" />
                                        <TextBlock Opacity="0.72" Text="{x:Bind Id}" TextTrimming="CharacterEllipsis" />
                                        <TextBlock Opacity="0.72" Text="{x:Bind MetadataLine}" />
                                    </StackPanel>
                                    <TextBlock Grid.Column="1" VerticalAlignment="Center" Opacity="0.72" Text="{x:Bind SizeLabel}" />
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </Grid>
            </Border>

            <Border Grid.Row="2" Grid.Column="1" Padding="18" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="16">
                <StackPanel Spacing="12">
                    <TextBlock FontSize="16" FontWeight="SemiBold" Text="Selection" />
                    <TextBlock FontWeight="SemiBold" Text="{x:Bind ViewModel.SelectedImageTitle, Mode=OneWay}" TextWrapping="WrapWholeWords" />
                    <TextBlock Opacity="0.72" Text="{x:Bind ViewModel.SelectedImageSubtitle, Mode=OneWay}" TextWrapping="WrapWholeWords" />
                    <TextBox Header="New tag" PlaceholderText="local/dev:latest" Text="{x:Bind ViewModel.NewTag, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                    <Button Command="{x:Bind ViewModel.TagImageCommand}" Content="Tag image" />
                    <Button Command="{x:Bind ViewModel.DeleteImageCommand}" Content="Delete image" />
                </StackPanel>
            </Border>
        </Grid>
    </ScrollViewer>
</Page>