<?xml version="1.0" encoding="utf-8" ?>
<Window
    x:Class="Porthole_App.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="Porthole"
    mc:Ignorable="d">
    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    <Grid x:Name="RootGrid">
        <Grid.RowDefinitions>
            <RowDefinition Height="48" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TitleBar
            x:Name="AppTitleBar"
            Title="{x:Bind ViewModel.WindowTitle, Mode=OneWay}"
            BackRequested="TitleBar_BackRequested"
            IsBackButtonVisible="{x:Bind NavFrame.CanGoBack, Mode=OneWay}"
            IsPaneToggleButtonVisible="True"
            PaneToggleRequested="TitleBar_PaneToggleRequested">
            <TitleBar.IconSource>
                <ImageIconSource ImageSource="Assets/AppIcon.ico" />
            </TitleBar.IconSource>
        </TitleBar>

        <NavigationView
            x:Name="NavView"
            Grid.Row="1"
            IsBackButtonVisible="Collapsed"
            IsPaneToggleButtonVisible="False"
            IsSettingsVisible="True"
            PaneDisplayMode="Left"
            AlwaysShowHeader="False"
            SelectionChanged="NavView_SelectionChanged">
            <NavigationView.MenuItems>
                <NavigationViewItem
                    Content="Dashboard"
                    IsSelected="True"
                    Tag="home">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE80F;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem Content="Images" Tag="images">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE7B8;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem Content="Containers" Tag="containers">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE8A5;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem Content="Sessions" Tag="sessions">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE7EF;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem Content="Networking" Tag="networking">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xF785;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem Content="Volumes" Tag="volumes">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xEDA2;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem Content="Run Wizard" Tag="run-wizard">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE70F;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
            </NavigationView.MenuItems>
            <Grid x:Name="ContentHostGrid">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <TextBlock
                    Margin="24,20,24,0"
                    FontSize="28"
                    FontWeight="SemiBold"
                    Text="{x:Bind ViewModel.CurrentSectionTitle, Mode=OneWay}" />
                <Frame Grid.Row="1" x:Name="NavFrame" Navigated="NavFrame_Navigated" />

                <Border
                    x:Name="SessionToolbarBorder"
                    Grid.Row="2"
                    Padding="16,8"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource AccentFillColorSecondaryBrush}"
                    BorderThickness="0,1,0,0">
                    <Grid ColumnSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <StackPanel
                            Orientation="Horizontal"
                            Spacing="10"
                            VerticalAlignment="Center">
                            <StackPanel Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
                                <FontIcon
                                    FontSize="12"
                                    Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"
                                    Glyph="&#xE7EF;" />
                                <FontIcon
                                    FontSize="10"
                                    Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"
                                    Glyph="&#xE710;" />
                            </StackPanel>
                            <TextBlock
                                VerticalAlignment="Center"
                                FontSize="12"
                                FontWeight="SemiBold"
                                Text="{x:Bind ViewModel.ActiveSessionDisplay, Mode=OneWay}" />
                            <ComboBox
                                x:Name="SessionPicker"
                                MinWidth="220"
                                DisplayMemberPath="Name"
                                IsEnabled="{x:Bind ViewModel.HasSessions, Mode=OneWay}"
                                ItemsSource="{x:Bind ViewModel.Sessions, Mode=OneWay}"
                                PlaceholderText="No sessions"
                                SelectedItem="{x:Bind ViewModel.SelectedSession, Mode=TwoWay}" />
                            <Button Command="{x:Bind ViewModel.RefreshSessionsCommand}" ToolTipService.ToolTip="Refresh sessions">
                                <FontIcon FontSize="12" Glyph="&#xE72C;" />
                            </Button>
                        </StackPanel>

                        <StackPanel
                            Grid.Column="1"
                            Orientation="Horizontal"
                            Spacing="12"
                            VerticalAlignment="Center">
                            <ProgressRing
                                Width="14"
                                Height="14"
                                IsActive="{x:Bind ViewModel.IsSessionLoading, Mode=OneWay}" />
                            <TextBlock
                                MaxWidth="380"
                                VerticalAlignment="Center"
                                FontSize="12"
                                Opacity="0.78"
                                Text="{x:Bind ViewModel.SessionStatus, Mode=OneWay}"
                                TextTrimming="CharacterEllipsis" />
                            <Button Click="OpenSessionsToolbarButton_Click" ToolTipService.ToolTip="Manage sessions">
                                <FontIcon FontSize="12" Glyph="&#xE8A7;" />
                            </Button>
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>
        </NavigationView>
    </Grid>
</Window>
