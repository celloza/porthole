<?xml version="1.0" encoding="utf-8"?>
<Application
    x:Class="Porthole_App.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Porthole_App">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <XamlControlsResources xmlns="using:Microsoft.UI.Xaml.Controls" />
                <!-- Other merged dictionaries here -->
            </ResourceDictionary.MergedDictionaries>
            <!-- Danger button: red-tinted subtle style for destructive actions -->
            <Style x:Key="DangerButtonStyle" TargetType="Button">
                <Setter Property="Foreground" Value="{ThemeResource SystemFillColorCriticalBrush}" />
                <Setter Property="Background" Value="Transparent" />
                <Setter Property="BorderBrush" Value="{ThemeResource SystemFillColorCriticalBrush}" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="CornerRadius" Value="6" />
                <Setter Property="Padding" Value="12,6" />
            </Style>
        </ResourceDictionary>
    </Application.Resources>
</Application>
